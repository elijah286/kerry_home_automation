# Runs the watchdog every few minutes and once shortly after boot.
# Pair with home-automation-watchdog.service (see that file for install steps).

[Unit]
Description=Timer for Home Automation API watchdog

[Timer]
OnBootSec=3min
OnUnitActiveSec=3min
AccuracySec=1min
RandomizedDelaySec=45
Persistent=true

[Install]
WantedBy=timers.target

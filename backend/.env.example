NODE_ENV=development
API_PORT=3001
WS_PORT=3002

# `npm run dev` starts Postgres + Redis + discovery-proxy via Docker Compose (matches URLs below).
# SKIP_DEV_DOCKER=1 to skip that step if you manage services yourself.
# SKIP_DEV_DOCKER=1

REDIS_URL=redis://localhost:6379
DATABASE_URL=postgresql://ha_user:ha_dev_password@localhost:5432/home_automation
MQTT_URL=mqtt://localhost:1883

# Auth
JWT_SECRET=change-me-to-a-random-string
JWT_EXPIRY=7d

# Home Assistant machine (for bridge connections)
HA_HOST=192.168.68.203

# Z-Wave JS Server (running on HA machine)
ZWAVE_WS_URL=ws://192.168.68.203:3000

# Lutron Caseta bridges
LUTRON_BRIDGE_1_HOST=
LUTRON_BRIDGE_2_HOST=

# Tesla API (optional legacy env fallbacks; prefer Fleet OAuth via UI + DB)
TESLA_ACCESS_TOKEN=
TESLA_REFRESH_TOKEN=

# Tesla Fleet API OAuth — register an app at https://developer.tesla.com and add this redirect URI there
TESLA_CLIENT_ID=
TESLA_CLIENT_SECRET=
TESLA_OAUTH_REDIRECT_URI=http://localhost:3000/settings/integrations/tesla/callback
# Region audience (NA default; EU e.g. https://fleet-api.prd.eu.vn.cloud.tesla.com)
TESLA_FLEET_AUDIENCE=https://fleet-api.prd.na.vn.cloud.tesla.com
# Optional override (default matches Tesla Fleet API docs)
# TESLA_FLEET_AUTH_HOST=fleet-auth.prd.vn.cloud.tesla.com

# Ecobee (thermostats) — create an Authorization Code app at https://www.ecobee.com/consumerportal (Developer)
# Redirect URI must be HTTPS with no port (Ecobee restriction); match Settings → Integrations → Ecobee.
# ECOBEE_BRIDGE_ENABLED=0
ECOBEE_API_KEY=
ECOBEE_OAUTH_REDIRECT_URI=
ECOBEE_ACCESS_TOKEN=
ECOBEE_REFRESH_TOKEN=

# UniFi Protect controllers (comma-separated IPs/hostnames)
UNIFI_HOSTS=
UNIFI_USERNAME=
UNIFI_PASSWORD=

# go2rtc (running on HA machine)
GO2RTC_URL=http://192.168.68.203:1984

# Matter controller (enable "Matter" under Settings → Integrations, or set to 1 here)
MATTER_BRIDGE_ENABLED=0
MATTER_STORAGE_PATH=./data/matter
MATTER_CONTROLLER_NAME=ha-matter-controller
MATTER_FABRIC_LABEL=Home Automation
MATTER_AUTO_CONNECT=1

# ESPHome native API (optional; prefer Settings → Integrations → ESPHome (LAN) JSON list)
ESPHOME_BRIDGE_ENABLED=1
# ESPHOME_DEVICES_JSON=[{"id":"node1","host":"192.168.1.50","encryptionKey":"..."}]

# Yamaha MusicCast receivers (comma-separated IPs)
YAMAHA_HOSTS=

# LAN discovery proxy — in dev (NODE_ENV≠production) the API defaults to http://127.0.0.1:39100 + the Compose secret
# after `npm run dev` starts Docker. Override via Settings → System or set LAN_DISCOVERY_PROXY_* / LAN_DISCOVERY_PROXY_AUTO=0.
# LAN_DISCOVERY_PROXY_URL=http://127.0.0.1:39100
# LAN_DISCOVERY_PROXY_SECRET=change-me-discovery-secret
# LAN_DISCOVERY_PROXY_AUTO=0
# LAN_DISCOVERY_PROXY_AUTO_URL=http://host.docker.internal:39100

# Meross — local HTTP only (meross_lan style; comma-separated device IPs on your LAN)
MEROSS_HOSTS=
# Optional signing key if automatic HTTP signing fails (from HA meross_lan diagnostics)
MEROSS_KEY=
# Optional per-IP keys when you have multiple devices (each has its own key): IP=key,IP2=key2 or newline-separated
MEROSS_HOST_KEYS=

# Pentair IntelliCenter (local TCP port 6681 — see Settings → Integrations)
# Set to 0 to force the bridge off even when enabled in the UI (rare).
# PENTAIR_BRIDGE_ENABLED=1
PENTAIR_HOST=
PENTAIR_PORT=6681
# Optional JSON when not using Settings UI: {"switch.spa_jets":12}
# PENTAIR_CIRCUIT_MAP=

# Roborock vacuums (valetudo or cloud mode)
ROBOROCK_MODE=valetudo
ROBOROCK_HOSTS=
ROBOROCK_USERNAME=
ROBOROCK_PASSWORD=

# Weather
WEATHER_PROVIDER=nws
OPENWEATHERMAP_API_KEY=

# Tesla (Powerwalls + Vehicles) - local gateway
TESLA_GATEWAY_HOST=
TESLA_GATEWAY_PASSWORD=

# Xbox SmartGlass
XBOX_LIVE_TOKEN=

# Sony BRAVIA TVs (comma-separated IPs)
SONY_TV_HOSTS=
SONY_TV_PSK=0000

# Vizio SmartCast TVs (comma-separated IPs)
VIZIO_TV_HOSTS=

# AI Assistant (OpenAI)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
OPENAI_WHISPER_MODEL=whisper-1
OPENAI_TTS_MODEL=tts-1
OPENAI_TTS_VOICE=nova

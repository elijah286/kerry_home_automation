#!/bin/sh
# Bump B, reset C on every push; commit the version file so the tag ships with the push.
set -e
ROOT="$(git rev-parse --show-toplevel)"
cd "$ROOT"

node scripts/version-bump-push.mjs

git add packages/frontend/src/lib/app-version.json
if git diff --cached --quiet; then
  exit 0
fi

git commit -m "chore: bump version (git push)" --no-verify

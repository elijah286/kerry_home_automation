# Railway assigns PORT automatically
PORT=3000

# Supabase project configuration (from Settings > API in Supabase dashboard)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-jwt-secret

# Shared secret for home instance tunnel authentication
# Must match TUNNEL_SECRET on the home backend
TUNNEL_SECRET=generate-a-strong-random-secret

# CORS origins (comma-separated)
CORS_ORIGINS=https://your-frontend-domain.com
